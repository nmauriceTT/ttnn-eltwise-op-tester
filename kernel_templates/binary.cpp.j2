#include <cstdint>
#include "api/compute/common.h"
#include "api/compute/tile_move_copy.h"
#include "api/compute/eltwise_binary.h"


namespace NAMESPACE {
void MAIN {
    uint32_t num_tiles = get_compile_time_arg_val(0);

    binary_op_init_common(tt::CBIndex::c_0, tt::CBIndex::c_1, tt::CBIndex::c_2);
    {{ LLK_OP_INIT }}(tt::CBIndex::c_0, tt::CBIndex::c_1);

    for (uint32_t i = 0; i < num_tiles; i++) {
        cb_wait_front(tt::CBIndex::c_0, 1);
        cb_wait_front(tt::CBIndex::c_1, 1);
        cb_reserve_back(tt::CBIndex::c_2, 1);

        tile_regs_acquire();
        {{ LLK_OP }}(tt::CBIndex::c_0, tt::CBIndex::c_1, 0, 0, 0);
        tile_regs_commit();

        tile_regs_wait();
        pack_tile(0, tt::CBIndex::c_2);
        tile_regs_release();

        cb_pop_front(tt::CBIndex::c_0, 1);
        cb_pop_front(tt::CBIndex::c_1, 1);
        cb_push_back(tt::CBIndex::c_2, 1);
    }
}
}  // namespace NAMESPACE
